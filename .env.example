# ─── Database ───
DB_PASSWORD=local-dev-password
DATABASE_URL=postgresql://glowup:local-dev-password@localhost:6432/glowup

# ─── Redis ───
REDIS_PASSWORD=local-dev-redis
REDIS_URL=redis://:local-dev-redis@localhost:6379

# ─── JWT ───
JWT_SECRET=dev-secret-change-in-production-must-be-256-bit-random-hex-string
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# ─── Encryption Keys (32 bytes hex) ───
BOT_TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
PAYMENT_ENCRYPTION_KEY=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210

# ─── Platform Bot ───
PLATFORM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
PLATFORM_ADMIN_TELEGRAM_IDS=
PLATFORM_ADMIN_USERNAMES=Sterld1996

# ─── Payment: Monobank ───
MONOBANK_MERCHANT_TOKEN=

# ─── Payment: LiqPay ───
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# ─── MinIO ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── URLs ───
API_BASE_URL=http://localhost:3000
MINI_APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─── AI Copywriter (optional) ───
# Do NOT commit real secrets. Put your real key only into local .env / server secrets.
OPENAI_API_KEY=
AI_MODEL=gpt-4.1-mini

# ─── App ───
NODE_ENV=development
PORT=3000
